# ── Database ──────────────────────────────────────────────────────────────────
# Local:   postgresql://postgres:postgres@localhost:5432/chatbot?sslmode=disable
# Neon:    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/chatbot?sslmode=require
# Railway: auto-provided as $DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatbot?sslmode=disable

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Get your token from https://huggingface.co/settings/tokens
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Optional: override the default model (Qwen/Qwen2.5-7B-Instruct)
# HF_REPO_ID=Qwen/Qwen2.5-7B-Instruct
# HF_MAX_TOKENS=2048
# HF_TEMPERATURE=0.8
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── External APIs (optional — tools will return errors if keys are missing) ───
# Alpha Vantage stock price: https://www.alphavantage.co/support/#api-key
ALPHA_VINTAGE_KEY=your_alphavantage_key_here

# OpenWeatherMap: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key_here

# ── App ───────────────────────────────────────────────────────────────────────
# Default user ID used when no auth is in place
LTM_USER_ID=u1
